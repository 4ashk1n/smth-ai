APP_NAME=smth-ai-module
APP_ENV=dev
APP_DEBUG=true

LLM_PROVIDER=gigachat
LLM_MODEL=GigaChat
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

GIGACHAT_CREDENTIALS=put_your_api_key_here
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_VERIFY_SSL_CERTS=true
GIGACHAT_CA_BUNDLE_FILE=

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smth
RECO_TOP_K=100
RECO_LOOKBACK_DAYS=180
RECO_HALF_LIFE_DAYS=30
RECO_MAX_ITEMS_PER_USER=200
RECO_NEIGHBORS_PER_ITEM=100
RECO_MIN_SCORE=0
RECO_WEIGHT_CF=0.5
RECO_WEIGHT_CATEGORY=0.25
RECO_WEIGHT_FRESHNESS=0.15
RECO_WEIGHT_POPULARITY=0.1
RECO_FRESHNESS_HALF_LIFE_DAYS=14
